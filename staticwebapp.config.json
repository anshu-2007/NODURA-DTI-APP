{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/static/*", "/api/*", "/*.{css,scss,js,png,gif,ico,jpg,svg,webp,woff,woff2,eot,ttf}"]
  },
  "routes": [
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "mimeTypes": {
    "woff": "font/woff",
    "woff2": "font/woff2"
  }
}
